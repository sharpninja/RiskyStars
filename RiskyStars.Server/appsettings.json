{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting": "Information",
      "Microsoft.AspNetCore.Routing": "Warning",
      "Grpc": "Information",
      "Grpc.AspNetCore.Server": "Information",
      "RiskyStars.Server": "Debug"
    },
    "Console": {
      "IncludeScopes": true,
      "TimestampFormat": "[yyyy-MM-dd HH:mm:ss] "
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    },
    "Limits": {
      "MaxConcurrentConnections": 100,
      "MaxConcurrentUpgradedConnections": 100,
      "MaxRequestBodySize": 16777216,
      "Http2": {
        "MaxStreamsPerConnection": 100,
        "InitialConnectionWindowSize": 131072,
        "InitialStreamWindowSize": 98304,
        "KeepAlivePingDelay": "00:00:30",
        "KeepAlivePingTimeout": "00:01:00"
      }
    }
  },
  "GamePersistence": {
    "SavePath": "GameSaves",
    "AutoSaveEnabled": true,
    "AutoRecoveryEnabled": true,
    "MaxBackupsPerGame": 10
  },
  "SessionManagement": {
    "SessionTimeoutMinutes": 30,
    "CleanupIntervalMinutes": 5,
    "MaxActiveGames": 50,
    "MaxPlayersPerGame": 8
  },
  "Grpc": {
    "MaxReceiveMessageSize": 16777216,
    "MaxSendMessageSize": 16777216,
    "EnableDetailedErrors": false,
    "CompressionProviders": ["gzip"]
  }
}
