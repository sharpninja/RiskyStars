{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "GamePersistence": {
    "SavePath": "GameSaves",
    "AutoSaveEnabled": true,
    "AutoRecoveryEnabled": true,
    "MaxBackupsPerGame": 10
  }
}
